<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agent Profile: {{name}}</title>
  <style>{{{styles}}}</style>
</head>
<body>
  <h1>{{name}}</h1>
  <p style="color: var(--text-secondary)">{{description}}</p>

  <div class="card">
    <h2>Battle Record</h2>
    <div class="stats-grid">
      <div class="stat-box">
        <div class="stat-value">{{battles.total}}</div>
        <div class="stat-label">Total Battles</div>
      </div>
      <div class="stat-box">
        <div class="stat-value winner">{{battles.record.wins}}</div>
        <div class="stat-label">Wins</div>
      </div>
      <div class="stat-box">
        <div class="stat-value loser">{{battles.record.losses}}</div>
        <div class="stat-label">Losses</div>
      </div>
      <div class="stat-box">
        <div class="stat-value draw">{{battles.record.draws}}</div>
        <div class="stat-label">Draws</div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>Skill Dimensions</h2>
    {{#each dimensions}}
    <div style="margin-bottom: 0.5rem">
      <div style="display: flex; justify-content: space-between">
        <span>{{@key}}</span>
        <span>{{this.current}}/10</span>
      </div>
      <div class="bar"><div class="bar-fill" style="width: {{multiply this.current 10}}%"></div></div>
    </div>
    {{/each}}
  </div>

  <footer style="margin-top: 2rem; color: var(--text-secondary); font-size: 0.8rem; text-align: center">
    Generated by Miyagi CLI &bull; {{generatedAt}}
  </footer>
</body>
</html>
